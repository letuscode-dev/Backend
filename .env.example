# Server
PORT=5000

# Database
# Prefer DATABASE_URL in production (Railway/Render/etc).
# Example:
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=

# Local dev fallback (used only when DATABASE_URL is empty)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=boutique_pos
# Optional
DB_PORT=3306

# Auth (JWT + refresh sessions)
# Generate a strong secret for production.
JWT_SECRET=change_me_in_production
JWT_ISSUER=t-one-pos
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# First-time setup only. Set to true to allow creating the first admin via /api/auth/bootstrap.
# After creating your admin account, set this back to false.
ALLOW_BOOTSTRAP=true

# Optional: lock CORS to your frontend origins (comma-separated). Leave blank to allow all origins.
# Example (Vite dev):
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN=

# Rate limiting store
# - memory: simple in-process counters (resets on restart; not shared between instances)
# - redis: production-ready shared store (requires REDIS_URL)
RATE_LIMIT_STORE=memory

# Redis (recommended in production for shared rate limiting)
# Example: redis://localhost:6379
# Example TLS: rediss://:password@your-redis-host:6380
REDIS_URL=
REDIS_PREFIX=tonepos

# Rate limiting (defaults are safe; tune for your shop)
# Login is limited by IP and also by username to slow brute-force.
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX_IP=50
RATE_LIMIT_LOGIN_MAX_USER=10

# Refresh is limited by IP to prevent token refresh abuse.
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX_IP=120
