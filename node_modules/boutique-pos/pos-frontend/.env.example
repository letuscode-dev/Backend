# Optional. Leave blank to use the Vite dev proxy (`/api` -> backend).
# Set this in production builds if the frontend is served separately.
# For the Android (Capacitor) app this should be set to a reachable backend URL,
# e.g. http://192.168.0.50:5000 (your laptop IP on the same Wi-Fi as the phone).
VITE_API_BASE_URL=
